AMAP_MAPS_API_KEY=your_amap_web_service_key

# ==================== LLM 配置（OpenAI 兼容协议）====================
# 可指向任意兼容 OpenAI 接口的服务：官方 OpenAI、中转站、DeepSeek、本地推理等
# 例如接入 GPT：
#   LLM_API_KEY=sk-xxxx
#   LLM_BASE_URL=https://your-relay-station.com/v1
#   LLM_MODEL=gpt-4o
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=1.3

# 旧版 DeepSeek 配置（当 LLM_API_KEY / LLM_BASE_URL 留空时作为回退）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DashScope（Qwen）配置，仅用于部分辅助 JSON 调用
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
SKIP_MCP_INIT=false
DEMO_MODE=false
